SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_CAMPAIGN_TABLE=campaign_totals
SUPABASE_CAMPAIGN_ROW_ID=last-mile-campaign
UPDATE_TOTAL_PASSWORD=choose-a-password

# Optional fallback if Supabase is not configured.
REACT_APP_CAMPAIGN_API_URL=https://chabadnf-backend.vercel.app/api
